# provider-fs — local-fs sidecar configuration
# Copy this file to .env and adjust values for your local setup.
# .env is gitignored; .env.example is committed.

# TCP port the sidecar listens on. Default: 7701
PROVIDER_FS_PORT=7701

# Bind address. Use 0.0.0.0 to expose on the network. Default: 127.0.0.1
PROVIDER_FS_HOST=127.0.0.1

# Absolute or relative path to the content directory.
# Defaults to ./content relative to the repo root.
PROVIDER_FS_CONTENT_ROOT=./content
