{
  "id": "sse-online-indicator",
  "version": "1",
  "description": "Assert sync status dot transitions to 'clean' (online) within 5 seconds after switching to HTTP provider.",
  "services": ["kanban-ui:dev", "provider-fs:sidecar"],
  "seed": "none",
  "url": "http://localhost:5173/",
  "prerequisites": {
    "sidecar": "http://localhost:3001",
    "notes": "Start provider-fs sidecar on port 3001 before running this scenario."
  },
  "actions": [
    { "type": "navigate", "url": "http://localhost:5173/" },
    { "type": "wait", "selector": "[data-testid='app-header']" },
    { "type": "click", "selector": "[data-testid='settings-btn']" },
    { "type": "wait", "selector": "[data-testid='settings-panel']" },
    { "type": "click", "selector": "[data-testid='provider-radio-http']" },
    { "type": "fill", "selector": "[data-testid='sidecar-url-input']", "value": "http://localhost:3001" },
    { "type": "click", "selector": "[data-testid='settings-save']" },
    { "type": "wait-for-gone", "selector": "[data-testid='settings-panel']" },
    {
      "type": "wait-for-attribute",
      "selector": "[data-testid='sync-status-dot']",
      "attribute": "data-sync-state",
      "value": "clean",
      "timeout": 5000
    }
  ],
  "assertions": [
    {
      "id": "indicator-online",
      "description": "Sync status dot shows 'clean' state after SSE connects",
      "selector": "[data-testid='sync-status-dot']",
      "check": "attribute-equals",
      "attribute": "data-sync-state",
      "value": "clean"
    },
    {
      "id": "indicator-aria-label",
      "description": "Sync status dot has accessible aria-label",
      "selector": "[data-testid='sync-status-dot']",
      "check": "has-attribute",
      "attribute": "aria-label"
    }
  ]
}
