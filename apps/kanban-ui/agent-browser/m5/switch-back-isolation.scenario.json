{
  "id": "switch-back-isolation",
  "version": "1",
  "description": "Switch to HTTP, perform an action, switch back to localStorage; assert state isolation between providers.",
  "services": ["kanban-ui:dev", "provider-fs:sidecar"],
  "seed": "none",
  "url": "http://localhost:5173/",
  "prerequisites": {
    "sidecar": "http://localhost:3001",
    "notes": [
      "Start provider-fs sidecar on port 3001.",
      "localStorage and sidecar must start with different (or empty) board states.",
      "The scenario verifies that switching providers shows different board content."
    ]
  },
  "actions": [
    { "type": "navigate", "url": "http://localhost:5173/?seed=m3" },
    { "type": "wait", "selector": "[data-testid='board'], [data-testid='empty-state']" },
    {
      "type": "count",
      "selector": "[data-testid^='item-card-']",
      "store": "localStorageItemCount"
    },
    { "type": "click", "selector": "[data-testid='settings-btn']" },
    { "type": "wait", "selector": "[data-testid='settings-panel']" },
    { "type": "click", "selector": "[data-testid='provider-radio-http']" },
    { "type": "fill", "selector": "[data-testid='sidecar-url-input']", "value": "http://localhost:3001" },
    { "type": "click", "selector": "[data-testid='settings-save']" },
    { "type": "wait-for-gone", "selector": "[data-testid='settings-panel']" },
    { "type": "wait", "selector": "[data-testid='board'], [data-testid='empty-state']", "timeout": 5000 },
    { "type": "click", "selector": "[data-testid='settings-btn']" },
    { "type": "wait", "selector": "[data-testid='settings-panel']" },
    { "type": "click", "selector": "[data-testid='provider-radio-localStorage']" },
    { "type": "click", "selector": "[data-testid='settings-save']" },
    { "type": "wait-for-gone", "selector": "[data-testid='settings-panel']" },
    { "type": "wait", "selector": "[data-testid='board'], [data-testid='empty-state']", "timeout": 5000 }
  ],
  "assertions": [
    {
      "id": "settings-panel-closed",
      "description": "Settings panel closed after switching back",
      "selector": "[data-testid='settings-panel']",
      "check": "not-exists"
    },
    {
      "id": "sync-dot-clean",
      "description": "Sync status dot shows 'clean' state when localStorage provider is active",
      "selector": "[data-testid='sync-status-dot']",
      "check": "attribute-equals",
      "attribute": "data-sync-state",
      "value": "clean"
    },
    {
      "id": "localStorage-items-restored",
      "description": "localStorage item count matches the count before switching",
      "selector": "[data-testid^='item-card-']",
      "check": "count-equals-stored",
      "stored": "localStorageItemCount"
    }
  ]
}
