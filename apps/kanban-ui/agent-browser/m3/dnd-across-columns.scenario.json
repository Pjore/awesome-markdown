{
  "id": "dnd-across-columns",
  "version": "1",
  "description": "Drag an item from column 'To Do' to column 'In Progress' (same swimlane). Assert the card now lives in the target column's cell.",
  "services": ["kanban-ui:dev"],
  "seed": "m3",
  "url": "http://localhost:5173/?seed=m3",
  "actions": [
    { "type": "navigate", "url": "http://localhost:5173/?seed=m3" },
    { "type": "wait", "selector": "[data-testid='board']" },
    {
      "type": "get-attribute",
      "selector": "[data-testid^='column-header-']",
      "attribute": "data-column-id",
      "nth": 0,
      "store": "sourceColumnId"
    },
    {
      "type": "get-attribute",
      "selector": "[data-testid^='column-header-']",
      "attribute": "data-column-id",
      "nth": 1,
      "store": "targetColumnId"
    },
    {
      "type": "get-attribute",
      "selector": "[data-testid^='swimlane-row-']",
      "attribute": "data-swimlane-id",
      "nth": 0,
      "store": "swimlaneId"
    },
    {
      "type": "get-attribute",
      "selector": "[data-testid^='item-card-']",
      "attribute": "data-item-id",
      "nth": 0,
      "store": "draggedItemId"
    },
    {
      "type": "drag-to",
      "source-selector-template": "[data-item-id='${draggedItemId}']",
      "target-selector-template": "[data-testid='cell-${targetColumnId}-${swimlaneId}']"
    },
    { "type": "wait", "ms": 500 }
  ],
  "assertions": [
    {
      "id": "item-in-target-column-cell",
      "description": "The dragged item now appears in the target column's cell",
      "selector-template": "[data-testid='cell-${targetColumnId}-${swimlaneId}'] [data-item-id='${draggedItemId}']",
      "check": "exists"
    },
    {
      "id": "item-not-in-source-column-cell",
      "description": "The dragged item is no longer in the source column's cell",
      "selector-template": "[data-testid='cell-${sourceColumnId}-${swimlaneId}'] [data-item-id='${draggedItemId}']",
      "check": "not-exists"
    }
  ]
}
