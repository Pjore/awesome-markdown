# kanban-ui Vite configuration
# Copy this file to .env and adjust values for your local setup.
# .env is gitignored; .env.example is committed.
# All VITE_* variables are inlined at build time and visible in the browser bundle.

# Default provider-fs sidecar URL pre-filled in the Settings panel.
# Users can override this at runtime via the Settings UI.
# Default: http://localhost:7701
# VITE_PROVIDER_FS_URL=http://localhost:7701

# Sync-engine URL used for SSE event stream and conflict API.
# In dev mode the Vite server proxies /sync-engine/* → http://127.0.0.1:7402
# automatically (same-origin, works through Coder/reverse-proxy environments).
# Only set this when the default proxy doesn't work, e.g. to point at a
# Coder subdomain proxy: https://7402--agent--workspace--owner.coder.example.com
# VITE_SYNC_ENGINE_URL=http://localhost:7402

# Zitadel OIDC auth (optional — omit both to disable auth gate).
# VITE_ZITADEL_ISSUER must match the `issuer` value from Zitadel's discovery doc.
# VITE_CLIENT_ID is the SPA (PKCE) client ID from the Zitadel console.
# VITE_ZITADEL_ISSUER=https://your-zitadel-instance.example.com
# VITE_CLIENT_ID=<paste-client-id-from-zitadel-console>
