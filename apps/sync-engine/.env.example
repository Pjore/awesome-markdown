# sync-engine configuration
# Copy this file to .env and adjust values for your local setup.
# .env is gitignored; .env.example is committed.

# Absolute path to the git repository root. Required.
SYNC_ENGINE_REPO_ROOT=/path/to/awesome-markdown

# Path to the watched content directory, relative to SYNC_ENGINE_REPO_ROOT.
# Default: content
# SYNC_ENGINE_CONTENT_DIR=content

# TCP port the sync-engine HTTP/SSE server listens on. Default: 7402
# SYNC_ENGINE_PORT=7402

# Bind address. Default: 127.0.0.1
# SYNC_ENGINE_HOST=127.0.0.1

# Git commit author metadata. Default values shown.
# SYNC_ENGINE_COMMIT_AUTHOR_NAME=awesome-markdown-sync
# SYNC_ENGINE_COMMIT_AUTHOR_EMAIL=sync@local

# File-system quiescence window before a batch is committed (ms). Default: 750
# SYNC_ENGINE_DEBOUNCE_MS=750

# ---------------------------------------------------------------------------
# Target branch for remote sync
# ---------------------------------------------------------------------------
# Branch the engine will pull from and push to.
# When unset, the engine auto-detects the current local branch (git branch --show-current).
# Set this explicitly when working on a feature branch to avoid syncing to main:
#   SYNC_ENGINE_TARGET_BRANCH=fix/my-feature
# SYNC_ENGINE_TARGET_BRANCH=main

# ---------------------------------------------------------------------------
# Remote git sync (disabled by default)
# ---------------------------------------------------------------------------
# SYNC_ENGINE_REMOTE_ENABLED=false
# SYNC_ENGINE_REMOTE_PULL_INTERVAL_MS=30000
# SYNC_ENGINE_REMOTE_PUSH_TIMEOUT_MS=15000

# GitHub Fine-Grained PAT with Contents: read/write on the target repository.
# Required when SYNC_ENGINE_REMOTE_ENABLED=true.
# NEVER commit a real token — keep this file as a template only.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
